# NVIDIA Startup AI Radar - configuracao minima
#
# Para demo local sem chave:
#   LLM_PROVIDER=none
#
# Para demo com Groq:
#   LLM_PROVIDER=groq
#   GROQ_API_KEY=coloque_sua_chave

LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Coleta web real. Deixe false para demo offline e testes previsiveis.
RADAR_ENABLE_WEB_FETCH=false

# Idioma padrao dos briefings.
RADAR_OUTPUT_LANGUAGE=pt

# Banco local usado pela interface e CLI.
PROFILE_REPOSITORY_BACKEND=sqlite

# Servidor da interface web. Troque a porta se 8000 estiver ocupada.
RADAR_WEB_HOST=127.0.0.1
RADAR_WEB_PORT=8000


# Opcionais avancados
# -------------------
# Use apenas se quiser ativar fallback pago de scraping, outros provedores de
# modelo ou trocar o comportamento local do indice de conhecimento.

FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev/v2/scrape

SCRAPER_MIN_TEXT_CHARS=500
SCRAPER_CACHE_TTL_HOURS=24
SCRAPER_CACHE_DIR=data/scrape_cache

NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

RAG_EMBEDDING_BACKEND=auto
RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBEDDING_CACHE_DB=data/rag_embedding_cache.sqlite
RAG_RERANKER=local
RAG_RERANKER_MODEL=ms-marco-MiniLM-L-12-v2
COHERE_API_KEY=
RAG_COHERE_API_KEY=
RAG_COHERE_MODEL=rerank-multilingual-v3.0
