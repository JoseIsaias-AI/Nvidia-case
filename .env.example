# Use NVIDIA NIM/OpenAI-compatible credentials in production.
# If no key is set, the pipeline runs with deterministic local fallbacks.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Optional fallback provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime knobs.
RADAR_OUTPUT_LANGUAGE=pt
RADAR_ENABLE_WEB_FETCH=false
